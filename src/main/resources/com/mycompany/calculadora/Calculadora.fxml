<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="275.0" prefWidth="290.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.calculadora.CalculadoraController">
   <children>
      <TitledPane animated="false" layoutY="-2.0" prefHeight="278.0" prefWidth="301.0" text="Calculadora">
        <content>
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="242.0" prefWidth="301.0">
               <children>
                  <TextField fx:id="ope1" layoutX="88.0" layoutY="14.0" />
                  <TextField fx:id="ope2" layoutX="88.0" layoutY="64.0" />
                  <Label layoutX="14.0" layoutY="18.0" text="Operando1" />
                  <Label layoutX="14.0" layoutY="67.0" text="Operando2" />
                  <Button fx:id="btnSumar" contentDisplay="CENTER" layoutX="50.0" layoutY="116.0" mnemonicParsing="false" onAction="#Sumar" prefHeight="50.0" prefWidth="50.0" text="+" textAlignment="JUSTIFY">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Button>
                  <Button fx:id="btnRestar" layoutX="100.0" layoutY="116.0" mnemonicParsing="false" onAction="#Restar" prefHeight="50.0" prefWidth="50.0" text="-">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Button>
                  <Button fx:id="btnDividir" layoutX="200.0" layoutY="116.0" mnemonicParsing="false" onAction="#Dividir" prefHeight="50.0" prefWidth="50.0" text="/">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Button>
                  <Button fx:id="btnMultiplicar" contentDisplay="CENTER" layoutX="150.0" layoutY="116.0" mnemonicParsing="false" onAction="#Multiplicar" prefHeight="50.0" prefWidth="50.0" text="*">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Button>
                  <TextField fx:id="resultado" editable="false" layoutX="88.0" layoutY="197.0" />
                  <Label layoutX="14.0" layoutY="192.0" text="Resultado" />
               </children>
            </AnchorPane>
        </content>
      </TitledPane>
   </children>
</AnchorPane>
